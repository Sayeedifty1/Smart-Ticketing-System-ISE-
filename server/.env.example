# =============================================================================
# TRANSIT TICKETING SERVER - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# MongoDB Connection (Prisma)
# Replace USERNAME, PASSWORD, and database name (transitDB) as needed.
# -----------------------------------------------------------------------------
DATABASE_URL="mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/transitDB?appName=Cluster0"

# -----------------------------------------------------------------------------
# JWT Secret — used to sign and verify login tokens.
# ⚠️ CHANGE THIS IN PRODUCTION: use a long, random string (e.g. 32+ chars).
# -----------------------------------------------------------------------------
JWT_SECRET=your_super_secret_key

# -----------------------------------------------------------------------------
# Stripe (payments). Use test keys for demo: https://dashboard.stripe.com/test/apikeys
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...

# -----------------------------------------------------------------------------
# Server Port
# -----------------------------------------------------------------------------
PORT=5001
